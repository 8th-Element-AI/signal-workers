# ClickHouse
CH_HOST=localhost
CH_PORT=8123
CH_DB=signal
CH_USER=default
CH_PASSWORD=

# Postgres (used by Cost lens for pricing rates)
PG_DSN=postgresql://postgres:@localhost:5433/signal

# Worker run loop
WORKER_BATCH=5000
WORKER_POLL_SEC=2.0

SIGNAL_PII_NER_MODEL=gravitee-io/bert-small-pii-detection       # default; set to gravitee-io/bert-small-pii-detection for the recommended tight ensemble
SIGNAL_PII_BATCH=4                         # thread-pool width for analyze_batch
SIGNAL_PII_CACHE_MAX=20000                 # LRU cap on the per-worker content cache

# ── Toxicity — device + perf ─────────────────────────────────────
SIGNAL_TOXICITY_DEVICE=cuda                  # cuda | cpu
SIGNAL_TOXICITY_MAX_LENGTH=128
SIGNAL_TOXICITY_FP16=true
SIGNAL_TOXICITY_BATCH_SIZE=32

# ── Toxicity — model paths ───────────────────────────────────────
# Set the root once; the four paths below are relative to it unless
# absolute. In a container with /opt/models mounted, set the root and
# leave the rest at defaults.
SIGNAL_TOXICITY_MODELS_ROOT=./models
SIGNAL_TOXICITY_FASTTEXT_PATH=fasttext/router_head.ftz
SIGNAL_TOXICITY_PI_PATH=transformers/prompt_injection
SIGNAL_TOXICITY_PI_ONNX_PATH=onnx_int8/prompt_injection
SIGNAL_TOXICITY_MOD_PATH=transformers/moderation

# ── Toxicity — FastText routing thresholds ───────────────────────
SIGNAL_TOXICITY_ATTACK_ROUTE=0.05
SIGNAL_TOXICITY_MODERATION_ROUTE=0.05
SIGNAL_TOXICITY_FAST_ALLOW=0.02
SIGNAL_TOXICITY_FASTTEXT_DIRECT=0.97

# ── Toxicity — BERT review thresholds (drive 0/1 verdicts) ──────
SIGNAL_TOXICITY_PI_THRESHOLD=0.50
SIGNAL_TOXICITY_HARMFUL_THRESHOLD=0.50
SIGNAL_TOXICITY_SEXUAL_THRESHOLD=0.50