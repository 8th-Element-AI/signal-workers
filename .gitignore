# ============================================================================
# Signal Workers — .gitignore
# ============================================================================

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.eggs/
build/
dist/

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/

# ---- Worker runtime state (per-lens watermarks — machine-local, not source) ----
state/
*.watermark
var/lib/signal-workers/

# ---- Generated / large telemetry data (regenerated; never commit) ----
signal_derived_metrics.csv
*_derived.csv
perf_derived*.csv
cost_derived*.csv
*.parquet

# ---- Secrets / local env (PG_DSN can carry credentials) ----
.env
.env.*
!.env.example
*.local
secrets/

models/
content_safety/scripts/
content_safety/tests/

# ---- Logs ----
*.log
logs/

# ---- Test / coverage ----
.pytest_cache/
.coverage
htmlcov/
.tox/

# ---- OS / editor cruft ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

test_scripts















